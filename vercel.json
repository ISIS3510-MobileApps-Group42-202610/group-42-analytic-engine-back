{
  "builds": [
    {
      "src": "analytics_backend/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "analytics_backend/wsgi.py"
    }
  ],
  "buildCommand": "bash build_files.sh"
}
